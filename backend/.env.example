# Copy to `.env` and fill in. (Windows: copy .env.example .env)

PORT=4000
# IMPORTANT: set NODE_ENV=production on deployed hosts (enables prod hardening).
NODE_ENV=development
# Comma-separated allowed origins; the first is treated as the frontend origin.
CORS_ORIGIN=http://localhost:3000

# Unauthenticated dev impersonation route (GET /auth/dev/login). Only takes
# effect when this is "true" AND NODE_ENV=development. Leave false/unset in prod.
ENABLE_DEV_LOGIN=false
# Proxy hops in front of the app so req.ip is the real client (rate limits,
# audit IPs): "false" = direct, "1" = behind one ALB/CloudFront, or a CIDR list.
# A blanket "true" is rejected (would trust a spoofable X-Forwarded-For chain).
TRUST_PROXY=false

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://tpc:tpc@localhost:5432/tpc?schema=public

# Redis (cache, sessions, BullMQ)
REDIS_URL=redis://localhost:6379

# Session signing — use long random strings (>= 16 chars)
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECRET=change-me-to-another-long-random-string
SESSION_COOKIE=tpc_session

# Public base URL of THIS API (for recruiter magic-link URLs in emails)
API_BASE_URL=http://localhost:4000

# SMTP for outbound email (recruiter magic links). Blank = log to console (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IIT Patna TPC <no-reply@iitp.ac.in>

# Microsoft Entra ID (Outlook SSO) — from your Azure app registration
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:4000/auth/callback

# S3-compatible object storage (resumes, JDs). MinIO locally / Cloudflare R2 / AWS S3.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=tpc-files
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
